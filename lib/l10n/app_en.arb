  "labelValidateModelData": "Validate Model Data",
  "tooltipValidateModelData": "The game validates model data when loading. Normally it silently fails and continues with broken data, which can cause invisible models or glitches. When enabled, NAMS surfaces the validation result as a dialog so you can see exactly which model failed and why.",
  "labelPreloadMaxDimension": "Preload Max Dimension",
  "tooltipPreloadMaxDimension": "Max texture size to preload into RAM at startup. 2048 = default, 4096 = preload up to 4K textures, 16384 = preload everything. Higher = longer loading but less stutter in-game.",
  "labelPreloadAllTextures": "Preload All Textures",
  "tooltipPreloadAllTextures": "Preload ALL textures into RAM regardless of size. Eliminates all texture pop-in stutter but needs 32GB+ RAM and makes startup significantly slower.",
  "labelEnableLodMod": "Enable LodMod",
  "tooltipEnableLodMod": "Master toggle for all LodMod visual patches/rewrites.",
  "labelLodMultiplier": "LOD Multiplier",
  "tooltipLodMultiplier": "Controls LOD (Level of Detail) draw distances. 0 = LODs disabled (best quality, no pop-in). 1 = vanilla. 10+ helps reduce AO bleed without fully disabling LODs. Lower values = better visuals but may cost performance.",
  "labelDisableManualCulling": "Disable Manual Culling",
  "tooltipDisableManualCulling": "Prevents models/geometry from randomly disappearing at certain distances or camera angles. Fixes things like the mall interior vanishing after crossing the bridge, buildings outside camp disappearing, etc. Rare ugly LOD models that would show up are filtered out.",
  "labelAoWidth": "AO Width",
  "tooltipAoWidth": "Multiplier for AO horizontal resolution. Vanilla AO runs at 1/4 screen res. 2.0 = half screen res (crisper AO but heavy). 1.5 is a good balance. Range: 0.1 - 2.0. Setting only one axis to 2 can be a lighter alternative.",
  "labelAoHeight": "AO Height",
  "tooltipAoHeight": "Multiplier for AO vertical resolution. Vanilla AO runs at 1/4 screen res. 2.0 = half screen res (crisper AO but heavy). 1.5 is a good balance. Range: 0.1 - 2.0. Both at 2.0 can cost ~10 FPS in worst case.",
  "labelShadowResolution": "Shadow Resolution",
  "tooltipShadowResolution": "Shadow map texture size. Higher = sharper shadows but heavier on GPU. 2048 = vanilla, 4096 = good upgrade, 8192 = very sharp. Must be power of 2. Sharpness depends on both resolution and distance (larger distance = more area to fit, so quality decreases).",
  "labelDistanceMultiplier": "Distance Multiplier",
  "tooltipDistanceMultiplier": "Multiplies the per-scene shadow draw distance. 2.0 = shadows visible twice as far. Vanilla: 1.0. Disable Min/Max below for this to work properly, or use them to restrict the range this multiplier sets.",
  "labelDistanceMinimum": "Distance Minimum",
  "tooltipDistanceMinimum": "Minimum shadow draw distance clamp. 0 = off (no minimum). Setting to ~70 with 8192 resolution matches vanilla quality while greatly increasing shadow distance.",
  "labelDistanceMaximum": "Distance Maximum",
  "tooltipDistanceMaximum": "Maximum shadow draw distance clamp. 0 = off (no maximum). Only worth setting if the default game distances cause performance issues.",
  "labelDistancePss": "Distance PSS",
  "tooltipDistancePss": "Enables PSS shadow distribution for more even shadow quality. 0 = off. Good values: 0.5 - 0.9. Looks great in some areas but may appear blurry in others. Should be set much larger than other distance values (~1500 for large open areas).",
  "labelFilterStrengthBias": "Filter Strength Bias",
  "tooltipFilterStrengthBias": "Adjusts shadow blur filter strength per-scene. 0 = off. -1 = sharper shadows. Positive = softer. Different areas use different strengths (forest = softer). Can be combined with Min/Max to restrict the range.",
  "labelFilterStrengthMin": "Filter Strength Min",
  "tooltipFilterStrengthMin": "Forces a minimum shadow filter strength across all areas. 0 = off. Game default varies per scene (usually ~4). Use to prevent shadows from being too sharp in any area.",
  "labelFilterStrengthMax": "Filter Strength Max",
  "tooltipFilterStrengthMax": "Forces a maximum shadow filter strength across all areas. 0 = off. Game default varies per scene (usually ~4). Use to prevent shadows from being too blurry in any area.",
  "labelHqShadowModels": "HQ Shadow Models",
  "tooltipHqShadowModels": "Uses real-time HQ models for shadows instead of static LQ models. Tree shadows will sway with the wind instead of being frozen. Experimental - works well in city ruins, could cause issues in rare areas.",
  "labelForceAllShadowModels": "Force All Shadow Models",
  "tooltipForceAllShadowModels": "Forces all models to cast shadows, including small objects like rocks and grass. Experimental - may rarely cause invisible models to cast shadows. No issues noticed so far.",
  "labelDisableVignette": "Disable Vignette",
  "tooltipDisableVignette": "Removes the dark vignette effect on screen edges. Some loading screens may still have it baked into textures.",
  "configAppliesOnRestart": "Applies on restart",
  "configAppliesLive": "Applies instantly (live)",
  "dropZoneBrowseFolder": "Or pick a folder",
  "labelGiEnabled": "Enable Global Illumination",
  "tooltipGiEnabled": "FAR-style global illumination. Big FPS gain at the cost of some lighting accuracy.",
  "labelGiWorkgroupSize": "GI Workgroup Size",
  "tooltipGiWorkgroupSize": "Number of light volumes processed per GI dispatch. 128 = vanilla quality, 64/32/16 = progressively faster but coarser. Lower values trade lighting fidelity for FPS.",
  "labelGiMinLightExtent": "GI Min Light Extent",
  "tooltipGiMinLightExtent": "Cull small distant lights from GI. 0.0 = no culling (all lights contribute), 0.5 = aggressive culling. Range 0.0-1.0.",
  "cardExperimental": "EXPERIMENTAL",
  "lodModResetButton": "Reset to defaults",
  "lodModResetConfirmTitle": "Reset LodMod settings?",
  "lodModResetConfirmBody": "This will reset every LodMod field on this tab to its default value. Your current values will be overwritten. Continue?",
  "lodModResetConfirmAction": "Reset",
  "lodModResetToast": "LodMod settings reset to defaults",
  "experimentalWarningTitle": "Experimental - will break things",
  "experimentalWarningBody": "These settings bypass game limits the engine relies on. They are NOT supported and are known to cause issues. Only enable if you understand what you're doing. NAMS and the launcher will not be debugged around problems caused by these.",
  "labelFpsUncapInMenus": "Uncap FPS in menus / loading",
  "tooltipFpsUncapInMenus": "Removes the 60 FPS lock during menus and loading screens. Loading feels faster and menu animations get smoother. Safe: gameplay is unaffected.\n\nLive-toggleable if it was enabled at game launch. If it was disabled at launch, toggling it on later requires a restart.",
  "labelFpsUncapInGameplay": "Uncap FPS in gameplay",
  "tooltipFpsUncapInGameplay": "Removes the 60 FPS lock during gameplay. WARNING: NieR:Automata's physics, animations, and cutscene timing are tied to the 60 FPS lock. Uncapping causes broken physics (jumping height, dodge i-frames), animation speed changes, audio desync in cutscenes, and softlocks in scripted sequences. Use only if you know exactly what trade-offs you're accepting.\n\nLive-toggleable if it was enabled at game launch. If it was disabled at launch, toggling it on later requires a restart.",
  "labelFpsLimit": "FPS Limit",
  "tooltipFpsLimit": "FPS cap applied when uncap is active. 0 = unlimited. Otherwise 60-1000 (NAMS clamps values out of range). Values below 60 are clamped because the game's internal spin-wait loop ignores frametimes longer than the vanilla 60fps target. Tip: capping at half your monitor's refresh rate gives smoother motion than vanilla 60 (e.g. 72 on 144Hz, 82 on 165Hz, 120 on 240Hz).",
  "tutorialValidateModel": "Shows you when a mod's model is broken instead of silently failing.",
  "labelValidateScripts": "Validate Scripts",
  "tooltipValidateScripts": "Show script errors as dialog instead of silently crashing.",
  "previewValidationDialog": "VALIDATION DIALOG",
  "previewScriptErrorDialog": "SCRIPT ERROR DIALOG",
  "labelLoadingStallHints": "Loading Stall Hints",
  "tooltipLoadingStallHints": "Show escalating hints when the loading screen takes too long. Helps identify missing or deleted mod files.",
  "labelFixWindTimerBug": "Fix Wind Timer Bug",
  "tooltipFixWindTimerBug": "Fixes a vanilla bug where wind animation stops after max playtime. Uses the game's speed factor instead.",
  "labelDisablePluginLoading": "Disable Plugin Loading",
  "tooltipDisablePluginLoading": "Skip loading all plugin DLLs (e.g. YoRHa Protocol workspace). All NAMS engine features still work.",
  "labelDisableContentFeatures": "Disable Content Features",
  "tooltipDisableContentFeatures": "Master switch for all content-layer features. When on, NAMS runs as a pure engine layer (mouse fixes, validation, heap tuning, crash fixes) without any item / weapon / outfit / quest / accessory mod support. Useful for benchmarking or isolating engine vs content issues.",
  "labelContentItems": "Items / Weapons / Shops",
  "tooltipContentItems": "Custom items, weapons, outfits and shop entries. Disable to play without any item-related mods. Requires restart.",
  "labelContentAccessories": "Accessories",
  "tooltipContentAccessories": "Custom accessories (face masks, lunar tear, masamune mask, etc.) and the accessory equip / unequip flow. Disable to play without accessory mods. Requires restart.",
  "labelContentAssembleMeshes": "Player Meshes",
  "tooltipContentAssembleMeshes": "Custom player meshes (mesh swaps, hair / outfit / mask overrides). Disable to render the vanilla player models unchanged. Requires restart.",
  "labelContentQuestIntegration": "Quests / Mails / Voice",
  "tooltipContentQuestIntegration": "Custom quests, custom mails, custom voice lines, and the quest UI integration that activates them. Disable to play without quest mods. Requires restart.",
  "labelContentEffectsApplier": "Effect Rules",
  "tooltipContentEffectsApplier": "Per-frame application of weapon / outfit effect rules to player stats (damage multipliers, dodge tweaks, immunities, etc.).",
  "labelContentEquipTracker": "Equip Tracker",
  "tooltipContentEquipTracker": "Detection of weapon equip / unequip changes. Drives effect rules and equip-time SDK callbacks.",
  "labelContentMcd": "Custom Text",
  "tooltipContentMcd": "In-game text customization (custom item names, descriptions, dialogue strings supplied by mods).",
  "labelContentBuddyRubySelector": "Buddy Outfit Selector (experimental)",
  "tooltipContentBuddyRubySelector": "Patches the global buddy conversation script to add a \"Change outfit\" entry that lists modded buddy outfits. Disable if the patched conversation script causes instability or interferes with other script mods.",
  "cardContentFeatures": "CONTENT FEATURES",
  "contentFeaturesDescription": "Per-feature toggles for the content layer. All default to ON. Useful for narrowing a problem down to a specific subsystem. Requires a game restart.",
  "labelDisableReShadeLoading": "Disable ReShade Loading",
  "tooltipDisableReShadeLoading": "Skip automatic ReShade DLL detection from the reshade/ folder and does not load it anymore.",
  "labelDisable3dmigotoLoading": "Disable 3DMigoto Loading",
  "tooltipDisable3dmigotoLoading": "Skip loading the 3DMigoto runtime from thirdparty/3dmigoto/. Turn off to stop loading shader mods.",
  "labelDisableTextureInjection": "Disable Texture Injection",
  "tooltipDisableTextureInjection": "Skip texture injection from the mods folder. Useful for isolating issues or if you don't want to use texture mods even though they are installed.",
  "labelOutfitSwapVisualEffects": "Outfit Swap Visual Effects",
  "tooltipOutfitSwapVisualEffects": "Play the visual effects during an outfit hot-swap: the pod spawn-in blinder animation, the curtain, and the hacking-screen glitch filter. Turn off for an instant, effect-free swap - the model still reloads. Takes effect immediately, no restart needed.",
  "labelExperimentalDefaultOutfits": "Default Outfits (experimental)",
  "tooltipExperimentalDefaultOutfits": "Lets you mark installed outfit mods as active from the moment the game starts, as if their files were placed in the game's data folder. When on, the mod details panel shows a star button per player model to set it as the boot default. Off by default while the feature stabilizes. Requires a game restart.",
  "labelDisableSplashScreen": "Disable Splash Screen",
  "tooltipDisableSplashScreen": "Skip the startup splash window shown while the game loads. The original game revealed its window before it was ready, causing resize and flicker artifacts; NAMS finished the splash so the window is only revealed once ready. Turning this on brings those vanilla startup artifacts back.",
