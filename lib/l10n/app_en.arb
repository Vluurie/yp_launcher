  "labelGiWorkgroupSize": "GI Workgroup Size",
  "tooltipGiWorkgroupSize": "Number of light volumes processed per GI dispatch. 128 = vanilla quality, 64/32/16 = progressively faster but coarser. Lower values trade lighting fidelity for FPS.",
  "labelGiMinLightExtent": "GI Min Light Extent",
